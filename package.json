{
  "name": "proje-a",
  "productName": "Proje A",
  "version": "2.1.0",
  "description": "Modüler yapıda proje geliştirme ve yönetim platformu - Yapı Bedeli, Proje Bedeli, Mevzuat ve Hesaplama modülleri",
  "author": "Proje Geliştirme Birimi",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "obfuscate": "node build.js",
    "build": "node build.js && npx electron-builder --win portable --project build-temp",
    "build:dir": "node build.js && npx electron-builder --win dir --project build-temp"
  },
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@fontsource/inter": "^5.2.8",
    "angular-expressions": "^1.5.1",
    "docx": "^9.5.1",
    "docxtemplater": "^3.67.0",
    "lodash": "^4.17.21",
    "mammoth": "^1.11.0",
    "officegen": "^0.6.5",
    "pizzip": "^3.2.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^34.0.1",
    "electron-builder": "^26.7.0",
    "electron-icon-builder": "^2.0.1",
    "electron-rebuild": "^3.2.9",
    "javascript-obfuscator": "^5.3.0"
  },
  "build": {
    "appId": "com.projea.platform",
    "productName": "Proje A",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "**/*",
      "!node_modules/**/README*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/*.md"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icons/icons/win/icon.ico"
    },
    "portable": {
      "artifactName": "ProjeA-${version}-Portable.${ext}"
    },
    "asar": true,
    "compression": "maximum"
  }
}
